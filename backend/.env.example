# App Configuration
APP_ENV=development
APP_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=workflow_db
DB_SSLMODE=disable

# Cache (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Events (Kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=workflow-backend-group
KAFKA_DEFAULT_TOPIC=workflow.events

# Authentication
JWT_SECRET=super_secret_jwt_key_please_change_in_production
